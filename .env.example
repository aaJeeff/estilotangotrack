# ---------------------------------------------------------------------------
# Camisetas Tracker — environment variables
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# Prisma reads `.env`; Next.js reads `.env` and `.env.local`.
# ---------------------------------------------------------------------------

# --- Database (Supabase Postgres) ---
# Pooled connection (PgBouncer, port 6543) used by the app at runtime.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) used by Prisma Migrate.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-region.pooler.supabase.com:5432/postgres"

# --- Supabase Auth / SDK ---
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Service-role key — SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- 17Track ---
SEVENTEENTRACK_API_KEY="your-17track-api-key"
SEVENTEENTRACK_WEBHOOK_SECRET="a-long-random-secret"

# --- Email (Resend) ---
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="Camisetas <pedidos@tudominio.com>"

# --- Cron protection ---
# Shared secret required to invoke /api/cron/tracking-sync.
CRON_SECRET="a-long-random-secret"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Admin bootstrap (used only by `npm run db:seed`) ---
# The two initial administrators. Created in Supabase Auth + mirrored in the User table.
ADMIN_1_EMAIL="admin1@tudominio.com"
ADMIN_1_PASSWORD="change-me-strong-password"
ADMIN_2_EMAIL="admin2@tudominio.com"
ADMIN_2_PASSWORD="change-me-strong-password"
